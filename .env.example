# SelfRepair compose stack environment.
#
# Copy to `.env` for local dev. Never commit real secrets.
# Production deployments should source these from a secret manager.

# --- core ----------------------------------------------------------------
SELFREPAIR_ENV=dev
SELFREPAIR_LOG_LEVEL=INFO

# --- postgres ------------------------------------------------------------
POSTGRES_USER=selfrepair
POSTGRES_PASSWORD=selfrepair
POSTGRES_DB=selfrepair

# --- security ------------------------------------------------------------
# Used to sign session cookies. Rotate per environment; long random string.
SELFREPAIR_SESSION_SECRET=dev-only-change-me
# Comma-separated list of allowed browser origins.
SELFREPAIR_CORS_ALLOW_ORIGINS=http://localhost:8080,http://localhost:3000
# HMAC secrets for inbound provider webhooks. Required in production.
SELFREPAIR_GITHUB_WEBHOOK_SECRET=
SELFREPAIR_GITLAB_WEBHOOK_SECRET=

# --- worker / sandbox ----------------------------------------------------
# `local` runs in-process for laptop dev. Use `docker` in production to
# run every repair inside the matrixlab sandbox container.
SELFREPAIR_SANDBOX_DRIVER=local
SELFREPAIR_SANDBOX_WORKDIR=/tmp/selfrepair/sandbox

# --- gitpilot (PR publishing) -------------------------------------------
SELFREPAIR_GITPILOT_URL=http://gitpilot:8000
SELFREPAIR_GITPILOT_TOKEN=

# --- Generic Repository Maintenance product (selfrepair-repo) -----------
# SelfRepair is GENERIC: the client is injected here (Agent-Matrix is only
# the first client). SelfRepair DIAGNOSES, PLANS, delegates to GitPilot,
# asks MatrixLab to validate, and REPORTS -- it never writes code itself.
SELFREPAIR_CLIENT_ID=agent-matrix
SELFREPAIR_WORKSPACE_ID=default
SELFREPAIR_CODER_PROVIDER=gitpilot
GITPILOT_URL=http://localhost:9000
SELFREPAIR_SANDBOX_PROVIDER=matrixlab
MATRIXLAB_URL=http://localhost:8765
# OpenAI-compatible LLM gateway (OllaBridge) for planner / risk classification.
# Keys look like ob_test_xxx / ob_live_xxx. NEVER read HF_TOKEN for the LLM.
OPENAI_BASE_URL=https://api.ollabridge.com/v1
OPENAI_API_KEY=                            # ob_test_xxx / ob_live_xxx (placeholder)
SELFREPAIR_PLANNER_MODEL=repo-planner
SELFREPAIR_RISK_MODEL=risk-classifier

# --- OllaBridge Cloud (LLM gateway) -------------------------------------
# OllaBridge Cloud is the official enterprise LLM gateway for the
# Agent-Matrix ecosystem. SelfRepair talks to it through the standard
# OpenAI-compatible /v1/chat/completions endpoint.
#
# Set the canonical OLLABRIDGE_* vars here. When SelfRepair runs as a
# subprocess of matrix-maintainer (or any orchestrator that injects the
# OPENAI_* envs instead), those are honored automatically as a fallback.
#
# Precedence: OLLABRIDGE_* > OPENAI_* > built-in defaults.
#
# NEVER commit a real key. Placeholders only — production keys start with
# `ob_` and must come from your secret manager.
OLLABRIDGE_ENABLED=false
OLLABRIDGE_BASE_URL=https://api.ollabridge.com/v1
OLLABRIDGE_API_KEY=                       # ob_xxxxxxxxxxxxxxxx (placeholder)
OLLABRIDGE_MODEL=qwen2.5:1.5b
OLLABRIDGE_TIMEOUT=120.0

# OpenAI-compatible aliases (used as fallback when OLLABRIDGE_* are unset).
# Leave blank unless you are wiring a non-OllaBridge OpenAI-compatible
# backend, or you are reproducing the env that matrix-maintainer injects.
# OPENAI_BASE_URL=https://api.ollabridge.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=qwen2.5:1.5b
