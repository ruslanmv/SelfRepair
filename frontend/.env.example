# Override the API base for `vite dev`. Defaults to http://localhost:8000.
# In production the SPA is served by nginx and /api is proxied server-side.
VITE_API_TARGET=http://localhost:8000

# Where the SPA's fetch wrapper sends requests. Leave blank to use the
# vite/nginx /api proxy (recommended). Set to an absolute URL only when
# Storybook or a remote dev backend is involved.
# VITE_API_BASE=/api

# Dev-only org pin. The session cookie supersedes this once a user
# logs in; until they do, every request is scoped to this org.
# VITE_DEV_ORG_ID=00000000-0000-0000-0000-000000000001

# When true, the SPA serves data from src/data/mock.js via MSW so
# Storybook / offline runs stay productive. Production builds must
# leave this false.
VITE_USE_MOCKS=false
